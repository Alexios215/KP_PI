<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- Название услуги -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Название услуги"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

        <EditText
                android:id="@+id/service_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Введите название"
                android:inputType="text"
                android:padding="8dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/editbox_background" />

        <!-- Описание услуги -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Описание"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

        <EditText
                android:id="@+id/service_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Введите описание (необязательно)"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:padding="8dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/editbox_background" />

        <!-- Горизонтальный контейнер для цены и длительности -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

            <!-- Цена -->
            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Цена (руб.)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                <EditText
                        android:id="@+id/service_price"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:padding="8dp"
                        android:background="@android:drawable/editbox_background"
                        android:gravity="center_vertical" />

            </LinearLayout>

            <!-- Длительность -->
            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Длительность (мин)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                <EditText
                        android:id="@+id/service_duration"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="0"
                        android:inputType="number"
                        android:padding="8dp"
                        android:background="@android:drawable/editbox_background"
                        android:gravity="center_vertical" />

            </LinearLayout>

        </LinearLayout>

        <!-- Категория -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Категория"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

        <EditText
                android:id="@+id/service_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Введите категорию"
                android:inputType="text"
                android:padding="8dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/editbox_background" />

    </LinearLayout>

</ScrollView>